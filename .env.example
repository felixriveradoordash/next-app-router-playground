# Copy to .env.local and fill in secrets (never commit .env.local)
# Values mirror Cursor MCP snowflake env (mcp.json → snowflake → env)

SNOWFLAKE_ACCOUNT=doordash
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=ADHOC
SNOWFLAKE_ROLE=

# Optional: absolute path to a large local export (streams first N rows only via /api/segmentation)
# SEGMENTATION_CSV_PATH=/Users/you/Desktop/exposure_profile_sample.csv
