# Copy to .env.local and fill in secrets. Never commit .env.local.

SNOWFLAKE_ACCOUNT=doordash
SNOWFLAKE_USER=
SNOWFLAKE_USERNAME=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=ADHOC
SNOWFLAKE_DATABASE=PRODDB
SNOWFLAKE_SCHEMA=FELIXRIVERA
SNOWFLAKE_ROLE=

# Override if you want a different source query.
SEGMENTATION_SNOWFLAKE_QUERY=SELECT * FROM PRODDB.FELIXRIVERA.NESTLE_ANALYSIS_SAMPLE
